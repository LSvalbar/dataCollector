{
  "Server": {
    "Urls": "http://0.0.0.0:5180"
  },
  "Persistence": {
    "Provider": "Sqlite",
    "ConnectionString": "Data Source=data\\enterprise.db",
    "AutoInitialize": true
  },
  "RealtimeState": {
    "OfflineAfterSeconds": 30
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "DataCollector.Server.Api": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
