<Window x:Class="DataCollector.Desktop.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:DataCollector.Desktop.Wpf"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="机加数采客户端"
        Width="1500"
        Height="900"
        MinWidth="1120"
        MinHeight="720"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <HierarchicalDataTemplate DataType="{x:Type local:OrganizationTreeNode}" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="0,1,0,1" ToolTip="{Binding Subtitle}">
                <TextBlock VerticalAlignment="Center"
                           FontSize="12.5"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Text="{Binding Title}" />
            </StackPanel>
        </HierarchicalDataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="18,20,18,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Margin="0,12,0,0"
                       VerticalAlignment="Center"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Text="机加数采客户端" />
            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                <TextBlock x:Name="ServerStatusTextBlock"
                           HorizontalAlignment="Right"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Text="服务状态：检测中" />
                <TextBlock x:Name="ApiBaseUrlTextBlock"
                           Margin="0,6,0,0"
                           HorizontalAlignment="Right"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="API：" />
                <TextBlock x:Name="LastOverviewRefreshTextBlock"
                           Margin="0,6,0,0"
                           HorizontalAlignment="Right"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="最近刷新：-" />
                <StackPanel Margin="0,14,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Width="120" Style="{StaticResource SecondaryButtonStyle}" Content="刷新全部" Click="RefreshAllButton_Click" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <TabControl x:Name="MainTabControl" Grid.Row="1" Margin="18,8,18,18">
            <TabItem x:Name="DeviceManagementTab" Header="设备管理">
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280" MinWidth="220" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock FontSize="17" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Text="设备树" />
                            <TreeView x:Name="DeviceTreeView"
                                      Grid.Row="1"
                                      Margin="0,12,0,0"
                                      MouseDoubleClick="DeviceTreeView_MouseDoubleClick"
                                      PreviewMouseRightButtonDown="DeviceTreeView_PreviewMouseRightButtonDown"
                                      SelectedItemChanged="DeviceTreeView_SelectedItemChanged">
                                <TreeView.ContextMenu>
                                    <ContextMenu x:Name="DeviceTreeContextMenu" Opened="DeviceTreeContextMenu_Opened">
                                        <MenuItem x:Name="RefreshTreeMenuItem" Header="&#x5237;&#x65B0;" Click="RefreshTreeMenuItem_Click" />
                                        <MenuItem x:Name="AddDeviceFromTreeMenuItem" Header="&#x6DFB;&#x52A0;&#x8BBE;&#x5907;" Click="AddDeviceFromTreeMenuItem_Click" />
                                        <Separator />
                                        <MenuItem x:Name="RenameTreeNodeMenuItem" Header="&#x91CD;&#x547D;&#x540D;" Click="RenameTreeNodeMenuItem_Click" />
                                    </ContextMenu>
                                </TreeView.ContextMenu>
                            </TreeView>
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Column="1"
                                  Width="6"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  Background="#D2D0CE"
                                  ShowsPreview="True" />

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <StackPanel>
                                <TextBlock x:Name="ScopeSummaryTextBlock"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Text="全部设备" />
                                <TextBlock x:Name="OverviewSummaryTextBlock"
                                           Margin="0,6,0,0"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Text="正在加载设备概览..." />
                            </StackPanel>
                        </Grid>

                        <WrapPanel x:Name="ScopeCardsPanel" Grid.Row="1" Margin="0,12,0,8" />

                        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                            <DataGrid x:Name="DevicesGrid"
                                      MouseDoubleClick="DevicesGrid_MouseDoubleClick"
                                      PreviewMouseRightButtonDown="DevicesGrid_PreviewMouseRightButtonDown">
                                <DataGrid.ContextMenu>
                                    <ContextMenu x:Name="DevicesGridContextMenu" Opened="DevicesGridContextMenu_Opened">
                                        <MenuItem x:Name="RefreshDevicesMenuItem" Header="刷新列表" Click="RefreshOverviewButton_Click" />
                                        <Separator />
                                        <MenuItem x:Name="EditDeviceMenuItem" Header="编辑设备" Click="EditDeviceButton_Click" />
                                        <MenuItem x:Name="DeleteDeviceMenuItem" Header="删除设备" Click="DeleteDeviceButton_Click" />
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="部门" Binding="{Binding DepartmentName}" Width="110" />
                                    <DataGridTextColumn Header="车间" Binding="{Binding WorkshopName}" Width="100" />
                                    <DataGridTextColumn Header="设备编码" Binding="{Binding DeviceCode}" Width="128" />
                                    <DataGridTextColumn Header="设备名称" Binding="{Binding DeviceName}" Width="150" />
                                    <DataGridTextColumn Header="系统版本" Binding="{Binding ControllerModel}" Width="180" />
                                    <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="120" />
                                    <DataGridTemplateColumn Header="在线" Width="84">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Padding="8,4" Background="{Binding OnlineBackground}" BorderBrush="#C8C6C4" BorderThickness="1">
                                                    <TextBlock HorizontalAlignment="Center" Foreground="{Binding OnlineForeground}" Text="{Binding MachineOnlineText}" />
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="当前状态" Width="92">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Padding="8,4" Background="{Binding StateBackground}" BorderBrush="#C8C6C4" BorderThickness="1">
                                                    <TextBlock HorizontalAlignment="Center" Foreground="{Binding StateForeground}" Text="{Binding StateText}" />
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="健康" Width="92">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Padding="8,4" Background="{Binding HealthBackground}" BorderBrush="#C8C6C4" BorderThickness="1">
                                                    <TextBlock HorizontalAlignment="Center" Foreground="{Binding HealthForeground}" Text="{Binding HealthText}" />
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="程序号" Binding="{Binding CurrentProgramNo}" Width="110" />
                                    <DataGridTextColumn Header="主轴转速" Binding="{Binding SpindleSpeedText}" Width="92" />
                                    <DataGridTextColumn Header="主轴负载" Binding="{Binding SpindleLoadText}" Width="96" />
                                    <DataGridTextColumn Header="采集质量" Binding="{Binding DataQualityText}" Width="110" />
                                    <DataGridTextColumn Header="最近采集" Binding="{Binding LastCollectedAtText}" Width="160" />
                                    <DataGridTextColumn Header="最近心跳" Binding="{Binding LastHeartbeatAtText}" Width="160" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="统计报表">
                <Grid Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <DockPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Text="统计日期" />
                                <DatePicker x:Name="ReportDatePicker" Width="148" Margin="12,0,0,0" />
                                <Button Width="110" Margin="12,0,0,0" Style="{StaticResource PrimaryButtonStyle}" Content="刷新报表" Click="RefreshReportButton_Click" />
                            </StackPanel>
                            <TextBlock x:Name="ReportSummaryTextBlock"
                                       DockPanel.Dock="Right"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Text="日报快照：-" />
                        </DockPanel>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <GroupBox Header="开机率公式">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="52" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Text="时间项" />
                                    <ComboBox x:Name="PowerOnMetricComboBox"
                                              Grid.Column="1"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValuePath="VariableName"
                                              IsEnabled="False" />
                                </Grid>
                                <Grid Grid.Row="1" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="52" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Text="制式工时" />
                                    <TextBlock x:Name="PowerOnStandardHoursTextBlock"
                                               Grid.Column="1"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Text="10 小时" />
                                </Grid>
                                <Grid Grid.Row="2" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Text="系数" />
                                    <TextBlock x:Name="PowerOnCoefficientTextBlock"
                                               Grid.Column="1"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Text="1" />
                                </Grid>
                                <TextBlock x:Name="PowerOnFormulaPreviewTextBlock"
                                           Grid.Row="3"
                                           Margin="0,12,0,0"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Text="当前公式：-" />
                                <TextBlock Grid.Row="3"
                                           Margin="0,40,0,0"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Text="当前开机率按 时间项 / 制式工时(小时) × 系数 自动计算。" />
                            </Grid>
                        </GroupBox>

                        <GroupBox Grid.Column="2" Header="利用率公式">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="52" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Text="时间项" />
                                    <ComboBox x:Name="UtilizationMetricComboBox"
                                              Grid.Column="1"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValuePath="VariableName"
                                              IsEnabled="False" />
                                </Grid>
                                <Grid Grid.Row="1" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="52" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Text="制式工时" />
                                    <TextBlock x:Name="UtilizationStandardHoursTextBlock"
                                               Grid.Column="1"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Text="10 小时" />
                                </Grid>
                                <Grid Grid.Row="2" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Text="系数" />
                                    <TextBlock x:Name="UtilizationCoefficientTextBlock"
                                               Grid.Column="1"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Text="1" />
                                </Grid>
                                <TextBlock x:Name="UtilizationFormulaPreviewTextBlock"
                                           Grid.Row="3"
                                           Margin="0,12,0,0"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Text="当前公式：-" />
                                <TextBlock Grid.Row="3"
                                           Margin="0,40,0,0"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Text="当前利用率按 时间项 / 制式工时(小时) × 系数 自动计算。" />
                            </Grid>
                        </GroupBox>
                    </Grid>

                    <StackPanel Grid.Row="2" Margin="0,12,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Width="130"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Content="公式配置"
                                Click="ConfigureFormulaButton_Click" />
                    </StackPanel>

                    <Border Grid.Row="3" Margin="0,18,0,0" Style="{StaticResource CardBorderStyle}">
                        <DataGrid x:Name="DailyReportGrid">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="车间" Binding="{Binding WorkshopName}" Width="110" />
                                <DataGridTextColumn Header="设备编码" Binding="{Binding DeviceCode}" Width="120" />
                                <DataGridTextColumn Header="设备名称" Binding="{Binding DeviceName}" Width="150" />
                                <DataGridTextColumn Header="当前状态" Binding="{Binding CurrentStateText}" Width="90" />
                                <DataGridTextColumn Header="开机时间(分钟)" Binding="{Binding PowerOnMinutesText}" Width="115" />
                                <DataGridTextColumn Header="加工时间(分钟)" Binding="{Binding ProcessingMinutesText}" Width="115" />
                                <DataGridTextColumn Header="等待时间(分钟)" Binding="{Binding WaitingMinutesText}" Width="115" />
                                <DataGridTextColumn Header="待机时间(分钟)" Binding="{Binding StandbyMinutesText}" Width="115" />
                                <DataGridTextColumn Header="关机时间(分钟)" Binding="{Binding PowerOffMinutesText}" Width="115" />
                                <DataGridTextColumn Header="开机率" Binding="{Binding PowerOnRateText}" Width="90" />
                                <DataGridTextColumn Header="利用率" Binding="{Binding UtilizationRateText}" Width="90" />
                                <DataGridTextColumn Header="采集质量" Binding="{Binding DataQualityText}" Width="110" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem x:Name="TimelineTab" Header="设备运行情况">
                <Grid Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Text="设备" />
                            <ComboBox x:Name="TimelineDeviceComboBox"
                                      Width="280"
                                      Margin="12,0,0,0"
                                      DisplayMemberPath="DisplayText"
                                      SelectedValuePath="DeviceId" />
                            <TextBlock Margin="20,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Text="日期" />
                            <DatePicker x:Name="TimelineDatePicker" Width="148" Margin="12,0,0,0" />
                            <Button Width="120" Margin="12,0,0,0" Style="{StaticResource PrimaryButtonStyle}" Content="刷新时间线" Click="RefreshTimelineButton_Click" />
                        </StackPanel>
                    </Border>

                    <WrapPanel x:Name="TimelineTotalsPanel" Grid.Row="1" Margin="0,18,0,10" />

                    <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                        <DataGrid x:Name="TimelineGrid">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="状态" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Padding="8,4" Background="{Binding StateBackground}" BorderBrush="#C8C6C4" BorderThickness="1">
                                                <TextBlock HorizontalAlignment="Center" Foreground="{Binding StateForeground}" Text="{Binding StateText}" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="开始时间" Binding="{Binding StartAtText}" Width="180" />
                                <DataGridTextColumn Header="截止时间" Binding="{Binding EndAtText}" Width="180" />
                                <DataGridTextColumn Header="时长(秒)" Binding="{Binding DurationSecondsText}" Width="110" />
                                <DataGridTextColumn Header="采集质量" Binding="{Binding DataQualityText}" Width="140" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="用户与角色">
                <Grid Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <TextBlock FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Text="用户、角色与权限矩阵" />
                    </Border>

                    <Grid Grid.Row="1" Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <GroupBox Header="用户">
                            <DataGrid x:Name="UsersGrid"
                                      PreviewMouseRightButtonDown="UsersGrid_PreviewMouseRightButtonDown">
                                <DataGrid.ContextMenu>
                                    <ContextMenu x:Name="UsersGridContextMenu" Opened="UsersGridContextMenu_Opened">
                                        <MenuItem x:Name="RefreshUsersMenuItem" Header="刷新" Click="RefreshSecurityButton_Click" />
                                        <MenuItem x:Name="AddUserMenuItem" Header="添加用户" Click="AddUserMenuItem_Click" />
                                        <Separator />
                                        <MenuItem x:Name="EditUserMenuItem" Header="编辑用户" Click="EditUserMenuItem_Click" />
                                        <MenuItem x:Name="DeleteUserMenuItem" Header="删除用户" Click="DeleteUserMenuItem_Click" />
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="用户名" Binding="{Binding UserName}" Width="120" />
                                    <DataGridTextColumn Header="显示名" Binding="{Binding DisplayName}" Width="110" />
                                    <DataGridTextColumn Header="部门" Binding="{Binding Department}" Width="110" />
                                    <DataGridTextColumn Header="角色" Binding="{Binding RoleCodesText}" Width="140" />
                                    <DataGridTextColumn Header="状态" Binding="{Binding EnabledText}" Width="80" />
                                    <DataGridTextColumn Header="最近登录" Binding="{Binding LastLoginAtText}" Width="160" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>

                        <GroupBox Grid.Column="2" Header="角色">
                            <DataGrid x:Name="RolesGrid"
                                      PreviewMouseRightButtonDown="RolesGrid_PreviewMouseRightButtonDown">
                                <DataGrid.ContextMenu>
                                    <ContextMenu x:Name="RolesGridContextMenu" Opened="RolesGridContextMenu_Opened">
                                        <MenuItem x:Name="RefreshRolesMenuItem" Header="刷新" Click="RefreshSecurityButton_Click" />
                                        <MenuItem x:Name="AddRoleMenuItem" Header="添加角色" Click="AddRoleMenuItem_Click" />
                                        <Separator />
                                        <MenuItem x:Name="EditRoleMenuItem" Header="编辑角色" Click="EditRoleMenuItem_Click" />
                                        <MenuItem x:Name="DeleteRoleMenuItem" Header="删除角色" Click="DeleteRoleMenuItem_Click" />
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="角色编码" Binding="{Binding RoleCode}" Width="100" />
                                    <DataGridTextColumn Header="角色名称" Binding="{Binding RoleName}" Width="100" />
                                    <DataGridTextColumn Header="说明" Binding="{Binding Description}" Width="170" />
                                    <DataGridTextColumn Header="权限数量" Binding="{Binding PermissionCount}" Width="90" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>

                        <GroupBox Grid.Column="4" Header="权限">
                            <DataGrid x:Name="PermissionsGrid">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="权限编码" Binding="{Binding PermissionCode}" Width="120" />
                                    <DataGridTextColumn Header="权限名称" Binding="{Binding PermissionName}" Width="110" />
                                    <DataGridTextColumn Header="说明" Binding="{Binding Description}" Width="180" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="部署说明">
                <Grid Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <TextBlock FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Text="客户端、服务端、Agent 的职责划分与部署方式" />
                    </Border>

                    <Grid Grid.Row="1" Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="20" Foreground="{StaticResource TextPrimaryBrush}" Text="&#xE7F4;" />
                                    <TextBlock Margin="0,10,0,0" FontSize="16" FontWeight="Bold" Text="客户端" />
                                    <TextBlock Margin="0,8,0,0" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap">
                                        客户端是给管理者、IT 运维和主管使用的操作界面。主要负责设备管理、报表查看、历史追溯、权限管理和公式配置。
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="20" Foreground="{StaticResource TextPrimaryBrush}" Text="&#xE7EE;" />
                                    <TextBlock Margin="0,10,0,0" FontSize="16" FontWeight="Bold" Text="服务端" />
                                    <TextBlock Margin="0,8,0,0" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap">
                                        服务端放在机房或中心服务器，负责统一接收 Agent 上传的数据，保存设备档案、公式、时间线、权限和报表结果，并把实时状态与历史时间线写入本地数据库。
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="20" Foreground="{StaticResource TextPrimaryBrush}" Text="&#xE83A;" />
                                    <TextBlock Margin="0,10,0,0" FontSize="16" FontWeight="Bold" Text="Agent" />
                                    <TextBlock Margin="0,8,0,0" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap">
                                        Agent 放在车间采集机上，直接连接机床网络。它负责采集 FOCAS 数据，并按当前 Agent 节点自动从服务端拉取设备清单；设备增删改后，不需要再手工改本地 Machines 列表。
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Text="你需要做什么" />
                                <TextBlock Margin="0,14,0,0" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap">
                                    1. 在机房准备一台中央服务主机，部署服务端和数据库。
                                </TextBlock>
                                <TextBlock Margin="0,10,0,0" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap">
                                    2. 每个车间至少准备一台可连接机床网络的 Agent 采集机，推荐双网卡。
                                </TextBlock>
                                <TextBlock Margin="0,10,0,0" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap">
                                    3. 在客户端录入部门、车间、设备、IP、端口和 Agent 节点，设备编码必须唯一。
                                </TextBlock>
                                <TextBlock Margin="0,10,0,0" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap">
                                    4. 在 Win10 机器上优先使用统一启动器，填写服务端地址和 Agent 节点；Agent 会自动从服务端下发所属设备。
                                </TextBlock>
                                <TextBlock Margin="0,10,0,0" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap">
                                    5. 如果机床能 ping 通但客户端仍显示离线，优先检查 Agent 是否启动、Agent 节点是否一致、设备是否真的绑定到了这个 Agent 节点、设备是否被禁用。
                                </TextBlock>
                                <TextBlock Margin="0,10,0,0" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap">
                                    6. 报表中的开机率、利用率公式由管理口径决定，可以在统计报表页直接维护。
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
