<Window x:Class="DataCollector.Desktop.Wpf.DeviceEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设备维护"
        Width="520"
        Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="Microsoft YaHei UI"
        Background="#F4F7FB">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,0,12" VerticalAlignment="Center" Text="车间编码" />
                <TextBox x:Name="WorkshopCodeTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,12" />

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,0,12" VerticalAlignment="Center" Text="车间名称" />
                <TextBox x:Name="WorkshopNameTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,12" />

                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,0,12" VerticalAlignment="Center" Text="设备编码" />
                <TextBox x:Name="DeviceCodeTextBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,12" />

                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,0,12" VerticalAlignment="Center" Text="设备名称" />
                <TextBox x:Name="DeviceNameTextBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,12" />

                <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,0,12" VerticalAlignment="Center" Text="厂家" />
                <TextBox x:Name="ManufacturerTextBox" Grid.Row="4" Grid.Column="1" Margin="0,0,0,12" />

                <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,0,0,12" VerticalAlignment="Center" Text="控制器" />
                <TextBox x:Name="ControllerModelTextBox" Grid.Row="5" Grid.Column="1" Margin="0,0,0,12" />

                <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,0,0,12" VerticalAlignment="Center" Text="协议" />
                <TextBox x:Name="ProtocolTextBox" Grid.Row="6" Grid.Column="1" Margin="0,0,0,12" />

                <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,0,0,12" VerticalAlignment="Center" Text="IP 地址" />
                <TextBox x:Name="IpTextBox" Grid.Row="7" Grid.Column="1" Margin="0,0,0,12" />

                <TextBlock Grid.Row="8" Grid.Column="0" Margin="0,0,0,12" VerticalAlignment="Center" Text="端口" />
                <TextBox x:Name="PortTextBox" Grid.Row="8" Grid.Column="1" Margin="0,0,0,12" />

                <TextBlock Grid.Row="9" Grid.Column="0" Margin="0,0,0,12" VerticalAlignment="Center" Text="Agent 节点" />
                <TextBox x:Name="AgentNodeTextBox" Grid.Row="9" Grid.Column="1" Margin="0,0,0,12" />
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Margin="0,16,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <CheckBox x:Name="EnabledCheckBox" VerticalAlignment="Center" Content="启用设备" IsChecked="True" Margin="0,0,12,0" />
            <Button Width="96" Margin="0,0,8,0" Content="保存" Click="SaveButton_Click" />
            <Button Width="96" Content="取消" Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
