<Window x:Class="DataCollector.Desktop.Wpf.DeviceEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设备维护"
        Width="620"
        Height="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardBorderStyle}" Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock FontFamily="Segoe Fluent Icons"
                           FontSize="20"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Text="&#xE8F1;" />
                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                    <TextBlock FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Text="设备档案维护" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="维护部门、车间、设备信息、网络地址和负责人。" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="0,18,0,0" Style="{StaticResource CardBorderStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid Margin="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="122" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="0" />
                        <RowDefinition Height="0" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBox x:Name="DepartmentCodeTextBox" Grid.Row="0" Grid.Column="1" Visibility="Collapsed" />
                    <TextBox x:Name="WorkshopCodeTextBox" Grid.Row="1" Grid.Column="1" Visibility="Collapsed" />

                    <TextBlock Grid.Row="2" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Text="部门名称" />
                    <TextBox x:Name="DepartmentNameTextBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,12" />

                    <TextBlock Grid.Row="3" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Text="车间名称" />
                    <TextBox x:Name="WorkshopNameTextBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,12" />

                    <TextBlock Grid.Row="4" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Text="设备编码" />
                    <TextBox x:Name="DeviceCodeTextBox" Grid.Row="4" Grid.Column="1" Margin="0,0,0,12" />

                    <TextBlock Grid.Row="5" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Text="设备名称" />
                    <TextBox x:Name="DeviceNameTextBox" Grid.Row="5" Grid.Column="1" Margin="0,0,0,12" />

                    <TextBlock Grid.Row="6" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Text="系统版本" />
                    <TextBox x:Name="SystemVersionTextBox" Grid.Row="6" Grid.Column="1" Margin="0,0,0,12" />

                    <TextBlock Grid.Row="7" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Text="负责人" />
                    <TextBox x:Name="ResponsiblePersonTextBox" Grid.Row="7" Grid.Column="1" Margin="0,0,0,12" />

                    <TextBlock Grid.Row="8" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Text="IP 地址" />
                    <TextBox x:Name="IpTextBox" Grid.Row="8" Grid.Column="1" Margin="0,0,0,12" />

                    <TextBlock Grid.Row="9" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Text="端口" />
                    <StackPanel Grid.Row="9" Grid.Column="1">
                        <TextBox x:Name="PortTextBox" Width="140" HorizontalAlignment="Left" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="Agent 节点" />
                        <ComboBox x:Name="AgentNodeComboBox"
                                  Margin="0,8,0,0"
                                  IsEditable="True"
                                  IsTextSearchEnabled="False"
                                  StaysOpenOnEdit="True" />
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,18,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <CheckBox x:Name="EnabledCheckBox" Margin="0,0,14,0" Content="启用设备" IsChecked="True" />
            <Button Width="108" Margin="0,0,8,0" Style="{StaticResource SecondaryButtonStyle}" Content="取消" Click="CancelButton_Click" />
            <Button Width="108" Style="{StaticResource PrimaryButtonStyle}" Content="保存" Click="SaveButton_Click" />
        </StackPanel>
    </Grid>
</Window>
