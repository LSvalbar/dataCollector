<Window x:Class="DataCollector.Desktop.Wpf.DeviceStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设备实时运行详情"
        Width="1040"
        Height="760"
        MinWidth="820"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardBorderStyle}" Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="DeviceTitleTextBlock" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Text="设备详情" />
                    <TextBlock x:Name="DeviceSubtitleTextBlock" Margin="0,8,0,0" Foreground="{StaticResource TextSecondaryBrush}" Text="当前设备的主要运行参数与实时状态。" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="LastUpdatedTextBlock" HorizontalAlignment="Right" Foreground="{StaticResource TextSecondaryBrush}" Text="最近更新：-" />
                    <TextBlock x:Name="DataQualityTextBlock" Margin="0,8,0,0" HorizontalAlignment="Right" Foreground="{StaticResource TextSecondaryBrush}" Text="数据质量：-" />
                </StackPanel>
            </Grid>
        </Border>

        <WrapPanel Grid.Row="1" Margin="0,18,0,10">
            <Border x:Name="CurrentStateBorder" Width="180" Margin="0,0,12,12" Padding="14" BorderBrush="#C8C6C4" BorderThickness="1">
                <StackPanel>
                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="当前状态" />
                    <TextBlock x:Name="CurrentStateTextBlock" Margin="0,8,0,0" FontSize="22" FontWeight="Bold" />
                </StackPanel>
            </Border>
            <Border x:Name="OnlineStateBorder" Width="180" Margin="0,0,12,12" Padding="14" BorderBrush="#C8C6C4" BorderThickness="1">
                <StackPanel>
                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="在线状态" />
                    <TextBlock x:Name="OnlineStateTextBlock" Margin="0,8,0,0" FontSize="22" FontWeight="Bold" />
                </StackPanel>
            </Border>
            <Border x:Name="HealthStateBorder" Width="180" Margin="0,0,12,12" Padding="14" BorderBrush="#C8C6C4" BorderThickness="1">
                <StackPanel>
                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="设备健康" />
                    <TextBlock x:Name="HealthStateTextBlock" Margin="0,8,0,0" FontSize="22" FontWeight="Bold" />
                </StackPanel>
            </Border>
            <Border x:Name="ProgramStateBorder" Width="220" Margin="0,0,12,12" Padding="14" BorderBrush="#C8C6C4" BorderThickness="1" Background="White">
                <StackPanel>
                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="当前程序" />
                    <TextBlock x:Name="ProgramTextBlock" Margin="0,8,0,0" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Text="-" />
                </StackPanel>
            </Border>
        </WrapPanel>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="MetricsItemsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel ItemWidth="420" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,12,12"
                                    Padding="10"
                                    Background="White"
                                    BorderBrush="{StaticResource CardBorderBrush}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Text="{Binding Label}" />
                                    <Border Grid.Column="1"
                                            Padding="10,8"
                                            Background="{Binding ValueBackground}"
                                            BorderBrush="#C8C6C4"
                                            BorderThickness="1">
                                        <TextBlock Foreground="{Binding ValueForeground}"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Value}"
                                                   TextWrapping="Wrap" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
