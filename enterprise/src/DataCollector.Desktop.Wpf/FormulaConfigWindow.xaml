<Window x:Class="DataCollector.Desktop.Wpf.FormulaConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="公式配置"
        Width="620"
        Height="500"
        MinWidth="580"
        MinHeight="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                   Text="默认下拉选项只显示常用时间项，需要更多列时可点击“添加选项”。" />

        <StackPanel Grid.Row="1" Margin="0,14,0,0" Orientation="Horizontal">
            <Button Width="110"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Content="添加选项"
                    Click="AddOptionButton_Click" />
            <TextBlock x:Name="VisibleOptionsSummaryTextBlock"
                       Margin="12,4,0,0"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Text="当前下拉选项：" />
        </StackPanel>

        <Grid Grid.Row="2" Margin="0,18,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <GroupBox Header="开机率">
                <Grid Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="82" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Text="时间项" />
                    <ComboBox x:Name="PowerOnMetricComboBox"
                              Grid.Column="1"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="VariableName" />

                    <TextBlock Grid.Row="1" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Text="制式工时" />
                    <TextBox x:Name="PowerOnStandardHoursTextBox"
                             Grid.Row="1"
                             Grid.Column="1"
                             Margin="0,10,0,0" />

                    <TextBlock Grid.Row="2" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Text="系数" />
                    <TextBox x:Name="PowerOnCoefficientTextBox"
                             Grid.Row="2"
                             Grid.Column="1"
                             Margin="0,10,0,0" />

                    <TextBlock x:Name="PowerOnPreviewTextBlock"
                               Grid.Row="3"
                               Grid.ColumnSpan="2"
                               Margin="0,14,0,0"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Text="当前公式：-" />
                </Grid>
            </GroupBox>

            <GroupBox Grid.Row="2" Header="利用率">
                <Grid Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="82" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Text="时间项" />
                    <ComboBox x:Name="UtilizationMetricComboBox"
                              Grid.Column="1"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="VariableName" />

                    <TextBlock Grid.Row="1" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Text="制式工时" />
                    <TextBox x:Name="UtilizationStandardHoursTextBox"
                             Grid.Row="1"
                             Grid.Column="1"
                             Margin="0,10,0,0" />

                    <TextBlock Grid.Row="2" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Text="系数" />
                    <TextBox x:Name="UtilizationCoefficientTextBox"
                             Grid.Row="2"
                             Grid.Column="1"
                             Margin="0,10,0,0" />

                    <TextBlock x:Name="UtilizationPreviewTextBlock"
                               Grid.Row="3"
                               Grid.ColumnSpan="2"
                               Margin="0,14,0,0"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Text="当前公式：-" />
                </Grid>
            </GroupBox>
        </Grid>

        <StackPanel Grid.Row="3" Margin="0,18,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Width="100" Margin="0,0,8,0" Style="{StaticResource SecondaryButtonStyle}" Content="取消" Click="CancelButton_Click" />
            <Button Width="100" Style="{StaticResource PrimaryButtonStyle}" Content="确定" Click="SaveButton_Click" />
        </StackPanel>
    </Grid>
</Window>
