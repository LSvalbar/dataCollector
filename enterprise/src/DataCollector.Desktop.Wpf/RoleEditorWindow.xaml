<Window x:Class="DataCollector.Desktop.Wpf.RoleEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="角色维护"
        Width="560"
        Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Text="角色维护" />

        <Grid Grid.Row="1" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Text="角色编码" />
            <TextBox x:Name="RoleCodeTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,12" />

            <TextBlock Grid.Row="1" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Text="角色名称" />
            <TextBox x:Name="RoleNameTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,12" />

            <TextBlock Grid.Row="2" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Text="说明" />
            <TextBox x:Name="DescriptionTextBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,12" />

            <TextBlock Grid.Row="3" VerticalAlignment="Top" Foreground="{StaticResource TextSecondaryBrush}" Text="权限" />
            <Border Grid.Row="3" Grid.Column="1" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" Padding="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="PermissionOptionsItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Margin="0,0,0,8"
                                          Content="{Binding DisplayText}"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Margin="0,18,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Width="108" Margin="0,0,8,0" Style="{StaticResource SecondaryButtonStyle}" Content="取消" Click="CancelButton_Click" />
            <Button Width="108" Style="{StaticResource PrimaryButtonStyle}" Content="保存" Click="SaveButton_Click" />
        </StackPanel>
    </Grid>
</Window>
