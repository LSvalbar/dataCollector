<Window x:Class="DataCollector.Launcher.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="机加数采启动器"
        Width="760"
        Height="500"
        MinWidth="700"
        MinHeight="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock FontSize="26"
                       FontWeight="Bold"
                       Text="机加数采启动器" />
            <TextBlock Grid.Row="1"
                       Margin="0,8,0,0"
                       Foreground="#666666"
                       Text="统一启动服务端、客户端和 Agent，并保存本机启动配置。" />

            <Grid Grid.Row="2" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock VerticalAlignment="Center" Text="服务端地址" />
                <TextBox x:Name="ServerBaseUrlTextBox" Grid.Column="1" Height="32" />

                <TextBlock Grid.Row="1" Margin="0,12,0,0" VerticalAlignment="Center" Text="Agent 节点" />
                <TextBox x:Name="AgentNodeNameTextBox" Grid.Row="1" Grid.Column="1" Height="32" Margin="0,12,0,0" />

                <TextBlock Grid.Row="2" Margin="0,12,0,0" VerticalAlignment="Top" Text="发布目录" />
                <Border Grid.Row="2"
                        Grid.Column="1"
                        Margin="0,12,0,0"
                        Padding="10,8"
                        BorderBrush="#8A8886"
                        BorderThickness="1"
                        Background="White">
                    <TextBlock x:Name="RuntimeRootTextBlock"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap" />
                </Border>

                <UniformGrid Grid.Row="3" Grid.ColumnSpan="2" Margin="0,24,0,0" Rows="2" Columns="2">
                    <Button MinHeight="46"
                            Margin="0,0,12,12"
                            Padding="12,8"
                            FontSize="14"
                            Content="启动服务端"
                            Click="StartServerButton_Click" />
                    <Button MinHeight="46"
                            Margin="0,0,0,12"
                            Padding="12,8"
                            FontSize="14"
                            Content="启动客户端"
                            Click="StartClientButton_Click" />
                    <Button MinHeight="46"
                            Margin="0,0,12,0"
                            Padding="12,8"
                            FontSize="14"
                            Content="启动 Agent"
                            Click="StartAgentButton_Click" />
                    <Button MinHeight="46"
                            Margin="0,0,0,0"
                            Padding="12,8"
                            FontSize="14"
                            Content="全部启动"
                            Click="StartAllButton_Click" />
                </UniformGrid>
            </Grid>

            <StackPanel Grid.Row="3"
                        Margin="0,18,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Width="112"
                        Height="38"
                        Margin="0,0,8,0"
                        Content="保存设置"
                        Click="SaveButton_Click" />
                <Button Width="112"
                        Height="38"
                        Content="关闭"
                        Click="CloseButton_Click" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
